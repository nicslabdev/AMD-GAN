# AMD-GAN Configuration (.env.example)
# Copy this file to .env and update with your actual values
# Do NOT commit .env to version control

# ===== DATA PATHS =====
# Path to CIC-IDS2017 dataset (CSV format)
DATA_CICIDS2017_PATH=./data/CIC-IDS2017.csv

# Path to UNSW-NB15 dataset (CSV format)
DATA_UNSW_PATH=./data/UNSW-NB15.csv

# Path to Edge-IIoT 2022 dataset (CSV format)
DATA_EDGEIIOT_PATH=./data/Edge-IIoT.csv

# ===== OUTPUT PATHS =====
# Base output directory for generated models and synthetic data
OUTPUT_BASE_DIR=./outputs

# Subdirectories (auto-created)
OUTPUT_MODELS_DIR=./outputs/models
OUTPUT_SYNTHETIC_DIR=./outputs/synthetic_data
OUTPUT_RESULTS_DIR=./outputs/results
OUTPUT_PLOTS_DIR=./outputs/plots

# ===== TRAINING PARAMETERS =====
# Random seed for reproducibility
RANDOM_SEED=42

# Latent dimension for GAN generator
LATENT_DIM=100

# Default batch size
DEFAULT_BATCH_SIZE=32

# Number of training epochs (can be overridden per class)
TRAINING_EPOCHS=200

# ===== RESOURCE LIMITS =====
# Maximum GPU memory allocation (in GB, 0 = auto)
GPU_MEMORY_GB=0

# Enable mixed precision training
MIXED_PRECISION=false

# ===== LOGGING =====
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable verbose output
VERBOSE=false

# ===== TENSORFLOW SETTINGS =====
# TensorFlow logging level (0=all, 1=info/warn/error, 2=warn/error, 3=error)
TF_CPP_MIN_LOG_LEVEL=2
